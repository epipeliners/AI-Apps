<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phone Tracker · AI Apps</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .expiring-soon { background-color: #fff3cd; }
    .expired { background-color: #f8d7da; }
    .inactive-row { display: none; }
    .show-inactive .inactive-row { display: table-row; }
    .table-container {
      overflow-x: auto;
      margin: 1.5rem 0;
      border-radius: 16px;
      border: 1px solid #e0e0e0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      white-space: nowrap;
    }
    th, td {
      padding: 10px 14px;
      text-align: left;
      vertical-align: middle;
      border-bottom: 1px solid #e0e0e0;
    }
    th {
      background-color: #1e3b5c;
      color: white;
      font-weight: 600;
      cursor: pointer;
      user-select: none;
    }
    td:nth-child(2) { white-space: normal; } /* Name */
    /* Keep date on one line */
    th:nth-child(7), td:nth-child(7) {
      white-space: nowrap;
      min-width: 100px;  /* ensures enough space */
    }
    
    th:nth-child(9), td:nth-child(9) { text-align: right; font-family: 'Courier New', monospace; }
    .filter-bar {
      margin-bottom: 1rem;
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }
  </style>
  <%
  function formatDate(dateStr) {
    const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    return String(d.getDate()).padStart(2,'0') + '-' + months[d.getMonth()] + '-' + d.getFullYear();
  }
  %>
</head>
<body>
  <%- include('../partials/header', { role }) %>

  <main>
    <div class="container">
      <div class="card">
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap;">
          <h2>📱 Phone Number Tracker</h2>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a href="/phone-tracker?reminder=true"><button style="width:auto; padding:0.7rem 1.5rem; background:#ffc107; color:#000;">⏰ Reminder (60 days)</button></a>
            <a href="/phone-tracker/create"><button style="width:auto; padding:0.7rem 1.5rem;">➕ Add Single</button></a>
            <a href="/phone-tracker/bulk"><button style="width:auto; padding:0.7rem 1.5rem;">📋 Bulk Import</button></a>
            <button id="deleteSelectedBtn" style="width:auto; padding:0.7rem 1.5rem; background:#dc2626; color:white;" onclick="deleteSelected()">🗑️ Delete Selected</button>
          </div>
        </div>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <!-- Filter bar -->
        <div class="filter-bar">
          <form method="GET" action="/phone-tracker" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <% if (role === 'admin' || role === 'boss') { %>
              <select name="web" onchange="this.form.submit()">
                <option value="all" <%= filterWeb === 'all' ? 'selected' : '' %>>All Webs</option>
                <% webs.forEach(w => { %>
                  <option value="<%= w %>" <%= filterWeb === w ? 'selected' : '' %>><%= w %></option>
                <% }) %>
              </select>
            <% } %>
            <label>Start:</label>
            <input type="date" name="startDate" value="<%= startDate %>" onchange="this.form.submit()">
            <label>End:</label>
            <input type="date" name="endDate" value="<%= endDate %>" onchange="this.form.submit()">
            <button type="submit" style="width:auto; padding:0.5rem 1rem;">Apply</button>
            <a href="/phone-tracker" style="text-decoration:none; color:#666;">Clear</a>
          </form>
          <a href="/phone-tracker/export?<%= exportQuery %>" target="_blank">
            <button style="width:auto; padding:0.5rem 1rem; background:#047857; color:white;">📥 Export CSV</button>
          </a>
          <button id="toggleInactiveBtn" style="width:auto; padding:0.5rem 1rem;" onclick="toggleInactive()">👻 Show Inactive</button>
        </div>

        <!-- Summary counts -->
        <% if (typeof summary !== 'undefined' && summary) { %>
          <div style="display:flex; gap:20px; margin:1rem 0; font-weight:600;">
            <span>Active: <strong style="color:#2e7d32;"><%= summary.active %></strong></span>
            <span>Expiring Soon: <strong style="color:#ffc107;"><%= summary.expiring_soon %></strong></span>
            <span>Expired: <strong style="color:#dc2626;"><%= summary.expired %></strong></span>
          </div>
        <% } %>

        <!-- Success/error messages -->
        <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>

        <!-- Bulk delete form -->
        <form id="bulkDeleteForm" method="POST" action="/phone-tracker/bulk-delete">
          <div class="table-container" id="tableContainer">
            <table>
              <thead>
                <tr>
                  <th><input type="checkbox" id="selectAll" onclick="toggleAll(this)"></th>
                  <th>No</th><th>Name</th><th>Bank</th><th>Code</th><th>Phone</th><th>Expired</th><th>Notes</th><th>Web</th><th>Credit</th><th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% subscriptions.forEach((sub, index) => { 
                  let rowClass = '';
                  const today = new Date(); today.setHours(0,0,0,0);
                  const exp = new Date(sub.expired); exp.setHours(0,0,0,0);
                  const diffDays = Math.ceil((exp - today) / (1000 * 60 * 60 * 24));
                  if (diffDays < 0) rowClass = 'expired';
                  else if (diffDays <= 60) rowClass = 'expiring-soon';

                  const isInactive = sub.notes && /expired|non active|banned/i.test(sub.notes);
                %>
                  <tr class="<%= rowClass %> <%= isInactive ? 'inactive-row' : '' %>">
                    <td><input type="checkbox" name="ids" value="<%= sub.id %>" class="rowCheckbox"></td>
                    <td><%= index + 1 %></td>   <!-- dynamic numbering -->
                    <td><%= sub.name %></td>
                    <td><%= sub.bank || '' %></td>
                    <td><%= sub.code %></td>
                    <td><%= sub.phone %></td>
                    <td><%= formatDate(sub.expired) %></td>
                    <td><%= sub.notes || '' %></td>
                    <td><%= sub.web %></td>
                    <td><%= sub.credit || '' %></td>
                    <td>
                      <a href="/phone-tracker/<%= sub.id %>/edit" class="action-link">Edit</a>
                      <% if (role === 'admin' || role === 'boss') { %>
                        <form method="POST" action="/phone-tracker/<%= sub.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete?');">
                          <button type="submit" class="btn-delete">Del</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    function toggleAll(source) {
      const checkboxes = document.querySelectorAll('.rowCheckbox');
      checkboxes.forEach(cb => cb.checked = source.checked);
    }

    function deleteSelected() {
      const checkboxes = document.querySelectorAll('.rowCheckbox:checked');
      if (checkboxes.length === 0) {
        alert('No rows selected.');
        return;
      }
      if (!confirm(`Delete ${checkboxes.length} selected entries?`)) return;
      document.getElementById('bulkDeleteForm').submit();
    }

    function toggleInactive() {
      const container = document.getElementById('tableContainer');
      container.classList.toggle('show-inactive');
      const btn = document.getElementById('toggleInactiveBtn');
      btn.textContent = container.classList.contains('show-inactive') ? '👻 Hide Inactive' : '👻 Show Inactive';
    }
  </script>
</body>
</html>