<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Subscription</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('../partials/header', { role }) %>

  <main>
    <div class="container">
      <div class="card" style="max-width:600px; margin:0 auto;">
        <h2>✏️ Edit Phone Entry</h2>
        <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
        <form method="POST">
          <label>Name (readonly)</label>
          <input type="text" value="<%= sub.name %>" readonly disabled>
          <label>Phone *</label>
          <input type="text" name="phone" value="<%= sub.phone %>" required>
          <label>Expired (YYYY-MM-DD) *</label>
          <input type="date" name="expired" value="<%= sub.expired %>" required>

          <!-- ✅ Notes with dropdown (admin/boss can type custom, others use dropdown) -->
          <label>Notes</label>
          <% if (role === 'admin' || role === 'boss') { %>
            <input type="text" name="notes" value="<%= sub.notes || '' %>" list="notesOptions">
            <datalist id="notesOptions">
              <option value="ACTIVE">
              <option value="EXPIRED">
              <option value="NON ACTIVE">
              <option value="BANNED">
            </datalist>
          <% } else { %>
            <select name="notes">
              <option value="ACTIVE" <%= sub.notes === 'ACTIVE' ? 'selected' : '' %>>ACTIVE</option>
              <option value="EXPIRED" <%= sub.notes === 'EXPIRED' ? 'selected' : '' %>>EXPIRED</option>
              <option value="NON ACTIVE" <%= sub.notes === 'NON ACTIVE' ? 'selected' : '' %>>NON ACTIVE</option>
              <option value="BANNED" <%= sub.notes === 'BANNED' ? 'selected' : '' %>>BANNED</option>
            </select>
          <% } %>

          <!-- ✅ Web field (editable for admin/boss, readonly for others) -->
          <label>Web</label>
          <% if (role === 'admin' || role === 'boss') { %>
            <input type="text" name="web" value="<%= sub.web || '' %>">
          <% } else { %>
            <input type="text" value="<%= sub.web %>" readonly disabled>
          <% } %>

          <label>Credit</label>
          <input type="text" name="credit" value="<%= sub.credit || '' %>">

          <button type="submit">Save Changes</button>
          <a href="/phone-tracker"><button type="button" class="secondary">Cancel</button></a>
        </form>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>