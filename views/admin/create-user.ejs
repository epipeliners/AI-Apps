<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create User · Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('../partials/header', { role }) %>

  <main>
    <div class="container">
      <div class="card" style="max-width:500px; margin:0 auto;">
        <h2>➕ Create New User</h2>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <form method="POST">
          <input type="email" name="email" placeholder="Email address" required>
          <input type="password" name="password" placeholder="Password" required>

          <label>Role</label>
          <select name="role">
            <option value="admin">Admin (Full Access)</option>
            <option value="boss">Boss (Full Access)</option>
            <option value="leader">Leader (HR Full + All Tools)</option>
            <option value="cs">CS (HR Own Data + Tools)</option>
            <option value="joker">Joker (HR Own Data + Tools)</option>
            <option value="user" selected>User (Calculator & Converter Only)</option>
          </select>

          <label>Web Access (for Phone Tracker)</label>
          <input type="text" name="web_access" placeholder="e.g., WebA, WebB">
          <small>Leave empty for admin/boss to see all webs.</small>

          <button type="submit">Create Account</button>
          <a href="/admin/users"><button type="button" class="secondary" style="margin-top:0.5rem;">Cancel</button></a>
        </form>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>