<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IP Whitelist & Logs · Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('../partials/header', { role }) %>

  <main>
    <div class="container">
      <div class="card">
        <h2>🛡️ IP Whitelist Management</h2>
        <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
        
        <h3>Current Whitelist</h3>
        <ul>
          <% whitelist.forEach(ip => { %>
            <li>
              <%= ip %>
              <form method="POST" action="/admin/whitelist/remove" style="display:inline; margin-left:10px;">
                <input type="hidden" name="ip" value="<%= ip %>">
                <button type="submit" class="btn-delete" style="padding:2px 8px;">Remove</button>
              </form>
            </li>
          <% }) %>
        </ul>

        <h3>Add IP or CIDR Range</h3>
        <form method="POST" action="/admin/whitelist/add">
          <input type="text" name="ip" placeholder="e.g., 192.168.1.100 or 10.0.0.0/8" required>
          <button type="submit">Add</button>
        </form>
        <p><small>Supports single IPs and CIDR notation. Changes take effect immediately.</small></p>

        <h3>📋 Recent Access Logs (Last 100)</h3>
        <div class="table-container">
          <table>
            <thead><tr><th>Time</th><th>IP</th><th>User</th><th>Method</th><th>Path</th><th>Status</th></tr></thead>
            <tbody>
              <% logs.forEach(log => { %>
                <tr>
                  <td><%= log.timestamp %></td>
                  <td><%= log.ip %></td>
                  <td><%= log.user %></td>
                  <td><%= log.method %></td>
                  <td><%= log.path %></td>
                  <td style="color:<%= log.status === 'BLOCKED' ? 'red' : 'green' %>;"><%= log.status %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>