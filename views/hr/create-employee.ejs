<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Employee · HR</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('../partials/header', { role }) %>

  <main>
    <div class="container">
      <div class="card" style="max-width:600px; margin:0 auto;">
        <h2>➕ New Employee</h2>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <form method="POST" enctype="multipart/form-data">
          <input type="text" name="employee_code" placeholder="Employee Code" required>
          <input type="text" name="full_name" placeholder="Full Name" required>
          <input type="email" name="email" placeholder="Email">
          <input type="text" name="phone" placeholder="Phone">
          <input type="text" name="department" placeholder="Department">
          <input type="text" name="position" placeholder="Position">
          <input type="date" name="join_date" placeholder="Join Date">
          <select name="status">
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
          </select>

          <!-- Photo upload -->
          <label>Photo (PNG only, max 2MB)</label>
          <input type="file" name="photo" accept="image/png" onchange="previewImage(event)">
          <img id="photoPreview" style="max-width:150px; margin-top:10px; display:none;">

          <% if (role === 'admin' || role === 'boss') { %>
            <label>Link to User Account</label>
            <select name="user_id">
              <option value="">-- None --</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>"><%= u.email %></option>
              <% }) %>
            </select>
            <label>Web</label>
            <input type="text" name="web" placeholder="e.g., WebA">
          <% } else { %>
            <input type="hidden" name="web" value="<%= userWeb %>">
          <% } %>

          <!-- ✅ ONLY ONE SUBMIT BUTTON -->
          <button type="submit">Save Employee</button>
          <a href="/hr/employees"><button type="button" class="secondary">Cancel</button></a>
        </form>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    function previewImage(event) {
      const preview = document.getElementById('photoPreview');
      const file = event.target.files[0];
      if (file) {
        preview.src = URL.createObjectURL(file);
        preview.style.display = 'block';
      }
    }
  </script>
</body>
</html>