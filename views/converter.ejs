<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Number Format Converter · AI Apps</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .converter-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }
    .converter-box {
      flex: 1;
      min-width: 300px;
    }
    .converter-box textarea {
      width: 100%;
      min-height: 400px;
      padding: 15px;
      font-family: 'Courier New', monospace;
      font-size: 1rem;
      border: 2px solid #e0e0e0;
      border-radius: 16px;
      resize: vertical;
    }
    .converter-box h3 {
      margin-bottom: 10px;
      color: #1e3b5c;
    }
    .convert-btn {
      background: #ff7a00;
      color: white;
      border: none;
      border-radius: 40px;
      padding: 12px 30px;
      font-weight: 600;
      cursor: pointer;
      margin: 20px 0;
    }
    .copy-btn {
      background: #047857;
      color: white;
      border: none;
      border-radius: 40px;
      padding: 8px 20px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
    }
    .toggle-group {
      display: inline-flex;
      background: white;
      border: 2px solid #e0e0e0;
      border-radius: 40px;
      overflow: hidden;
      margin-left: 20px;
    }
    .toggle-btn {
      padding: 10px 20px;
      border: none;
      background: white;
      font-weight: 600;
      cursor: pointer;
      color: #1e3b5c;
    }
    .toggle-btn.active {
      background: #ff7a00;
      color: white;
    }
  </style>
</head>
<body>
  <%- include('partials/header', { role }) %>

  <main>
    <div class="container">
      <div class="card">
        <div style="display:flex; align-items:center; flex-wrap:wrap; gap:10px;">
          <h2>🔄 Number Format Converter</h2>
          <div class="toggle-group" id="directionToggle">
            <button class="toggle-btn active" data-dir="eu2us">🇪🇺 EU → 🇺🇸 US</button>
            <button class="toggle-btn" data-dir="us2eu">🇺🇸 US → 🇪🇺 EU</button>
          </div>
        </div>
        <p>Paste numbers with any separator (tabs, spaces) – layout preserved</p>

        <div class="converter-container">
          <div class="converter-box">
            <h3>📋 Input</h3>
            <textarea id="inputArea" placeholder="Paste your numbers here...&#10;Example EU: 1.837.492&#10;4.325.004,1&#10;Example US: 1,837,492&#10;4,325,004.10"></textarea>
          </div>
          <div class="converter-box">
            <h3>✅ Output</h3>
            <textarea id="outputArea" readonly placeholder="Converted numbers will appear here..."></textarea>
            <button class="copy-btn" onclick="copyOutput()">📋 Copy to Clipboard</button>
          </div>
        </div>

        <button class="convert-btn" onclick="convertNumbers()">🔄 Convert</button>
        <button class="clear-btn" onclick="clearAll()">🗑️ Clear</button>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

<script>
  let currentDirection = 'eu2us';

  // Toggle buttons
  const toggleBtns = document.querySelectorAll('.toggle-btn');
  toggleBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      toggleBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      currentDirection = this.dataset.dir;
      if (document.getElementById('inputArea').value.trim()) {
        convertNumbers();
      }
    });
  });

  // Convert a single number string (without surrounding text) from source to target format
  function convertNumberString(numStr, fromFormat) {
    if (!numStr) return numStr;
    
    // Remove parentheses if present (negative indicator)
    let isNegative = false;
    let cleanStr = numStr.trim();
    if (cleanStr.startsWith('(') && cleanStr.endsWith(')')) {
      isNegative = true;
      cleanStr = cleanStr.slice(1, -1);
    } else if (cleanStr.startsWith('-')) {
      isNegative = true;
      cleanStr = cleanStr.substring(1);
    }

    // Parse based on source format
    let value;
    if (fromFormat === 'eu') {
      // EU: dots = thousand sep, comma = decimal
      let temp = cleanStr.replace(/\./g, '');
      temp = temp.replace(/,/g, '.');
      value = parseFloat(temp);
    } else {
      // US: commas = thousand sep, dot = decimal
      let temp = cleanStr.replace(/,/g, '');
      value = parseFloat(temp);
    }

    if (isNaN(value)) return numStr; // couldn't parse, return original

    if (isNegative) value = -value;

    // Format to target
    let rounded = Math.round(value * 100) / 100;
    let parts = rounded.toString().split('.');
    let integer = parts[0].replace('-', ''); // handle sign separately
    let decimal = parts.length > 1 ? parts[1] : '';
    let sign = value < 0 ? '-' : '';

    if (currentDirection === 'eu2us') {
      // Target: US
      integer = integer.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      if (decimal === '') return sign + integer;
      if (decimal.length === 1) decimal += '0';
      return sign + integer + '.' + decimal;
    } else {
      // Target: EU
      integer = integer.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      if (decimal === '') return sign + integer;
      if (decimal.length === 1) decimal += '0';
      return sign + integer + ',' + decimal;
    }
  }

  // Find all number-like substrings in a line and replace them
  function convertLine(line) {
    if (!line.trim()) return line;

    // Regex to match EU or US numbers (with optional thousand separators and decimal)
    // This pattern matches: optional sign/parentheses, digits with separators, optional decimal part
    const numberPattern = /(\(?-?\d{1,3}(?:[.,]\d{3})*(?:[.,]\d+)?\)?)/g;
    
    return line.replace(numberPattern, (match) => {
      // Determine if match is EU or US based on current direction's source
      const fromFormat = (currentDirection === 'eu2us') ? 'eu' : 'us';
      // If the match looks like a number, convert it
      if (/[\d]/.test(match)) {
        return convertNumberString(match, fromFormat);
      }
      return match;
    });
  }

  function convertNumbers() {
    const input = document.getElementById('inputArea').value;
    const rows = input.split('\n');
    const outputRows = rows.map(row => convertLine(row));
    document.getElementById('outputArea').value = outputRows.join('\n');
  }

  function copyOutput() {
    const output = document.getElementById('outputArea');
    output.select();
    document.execCommand('copy');
    alert('Copied to clipboard!');
  }

  function clearAll() {
    document.getElementById('inputArea').value = '';
    document.getElementById('outputArea').value = '';
  }

  document.getElementById('inputArea').addEventListener('paste', function(e) {
    setTimeout(convertNumbers, 50);
  });
</script>
</body>
</html>