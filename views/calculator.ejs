<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pretty Easy Calculator · AI Apps</title>
    <link rel="stylesheet" href="/style.css">
    <!-- Calculator-specific styles (scoped) -->
    <style>
        /* Override some global styles for calculator container */
        .calc-wrapper {
            max-width: 1500px;
            margin: 0 auto;
            background: transparent;
        }
        /* Keep calculator original styles with minor adjustments */
        .calc-card {
            background: white;
            border-radius: 36px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
            padding: 32px 32px 40px;
            margin: 20px 0;
        }
        .calc-card h1 {
            font-size: 2rem;
            font-weight: 600;
            color: #1e3b5c;
            margin: 0 0 8px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .calc-card h1 small {
            font-size: 0.9rem;
            background: #1e3b5c;
            color: white;
            padding: 4px 16px;
            border-radius: 40px;
            font-weight: 400;
        }
        .badge-2d {
            background: #d97706;
            color: white;
            padding: 4px 16px;
            border-radius: 40px;
            font-size: 0.8rem;
        }
        .bulk-section {
            background: #f8fafc;
            border-radius: 28px;
            padding: 24px;
            margin: 20px 0 28px 0;
            border: 2px solid #e2e8f0;
        }
        .bulk-title {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }
        .bulk-title h3 {
            margin: 0;
            color: #1e3b5c;
            font-size: 1.2rem;
        }
        .bulk-badge {
            background: #1e3b5c;
            color: white;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.8rem;
        }
        .feature-badge {
            background: #d97706;
            color: white;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.8rem;
        }
        #bulkInput {
            width: 100%;
            min-height: 150px;
            padding: 20px;
            border: 2px solid #e2e8f0;
            border-radius: 20px;
            font-size: 1rem;
            font-family: 'Courier New', monospace;
            background: white;
            resize: vertical;
            margin-bottom: 20px;
            line-height: 1.6;
        }
        .bulk-options {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            align-items: center;
        }
        .operator-selector {
            display: flex;
            gap: 8px;
            background: white;
            padding: 6px;
            border-radius: 40px;
            border: 2px solid #e2e8f0;
        }
        .op-option {
            padding: 10px 25px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.1s;
            font-size: 0.95rem;
        }
        .op-option.selected {
            background: #1e3b5c;
            color: white;
        }
        .fill-btn {
            background: #1e3b5c;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 12px 35px;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }
        .fill-btn:hover {
            background: #0a2b46;
            transform: scale(1.02);
        }
        .clear-btn {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 40px;
            padding: 10px 28px;
            font-weight: 500;
            color: #153e60;
            cursor: pointer;
        }
        .reset-numbers-btn {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 40px;
            padding: 10px 28px;
            font-weight: 500;
            color: #153e60;
            cursor: pointer;
        }
        .reset-numbers-btn:hover {
            background: #fee2e2;
            border-color: #dc2626;
        }
        .preview-count {
            margin-left: auto;
            color: #1e3b5c;
            font-size: 0.95rem;
            background: white;
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 600;
            border: 2px solid #e2e8f0;
        }
        /* DUAL TOTAL SECTION */
        .total-section {
            background: linear-gradient(135deg, #1e3b5c 0%, #2a4a73 100%);
            border-radius: 32px;
            padding: 20px 30px;
            margin: 20px 0 15px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: white;
            border: 2px solid #e2e8f0;
        }
        .total-label {
            font-size: 1.3rem;
            font-weight: 500;
        }
        .total-value {
            font-size: 2.2rem;
            font-weight: 700;
            font-family: 'Courier New', monospace;
            word-break: break-word;
            text-align: right;
            max-width: 70%;
        }
        .total-section-secondary {
            background: linear-gradient(135deg, #047857 0%, #059669 100%);
            border-radius: 32px;
            padding: 20px 30px;
            margin: 15px 0 28px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: white;
            border: 2px solid #e2e8f0;
        }
        .total-secondary-label {
            font-size: 1.3rem;
            font-weight: 500;
        }
        .total-secondary-value {
            font-size: 2.2rem;
            font-weight: 700;
            font-family: 'Courier New', monospace;
            word-break: break-word;
            text-align: right;
            max-width: 70%;
        }
        .table-container {
            overflow-x: auto;
            overflow-y: auto;
            max-height: 500px;
            border-radius: 24px;
            border: 2px solid #e2e8f0;
            background: #f8fafc;
            padding: 5px;
            margin-bottom: 25px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 20px;
            min-width: 1200px;
        }
        th {
            background: #1e3b5c;
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 18px 12px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        td {
            padding: 12px 8px;
            border-bottom: 1px solid #e2e8f0;
            vertical-align: middle;
            background: white;
        }
        .input-field {
            width: 280px;
            min-height: 60px;
            padding: 12px;
            border: 2px solid #d0ddee;
            border-radius: 16px;
            font-family: 'Courier New', monospace;
            font-size: 1rem;
            line-height: 1.4;
            text-align: left;
            background: white;
            resize: vertical;
            overflow: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        .input-field:focus {
            outline: none;
            border-color: #1e3b5c;
            box-shadow: 0 0 0 4px rgba(30, 59, 92, 0.1);
        }
        .operator-badge {
            background: #e5effa;
            border: 2px solid #1e3b5c;
            border-radius: 30px;
            padding: 12px 20px;
            font-size: 1.3rem;
            font-weight: 700;
            color: #1e3b5c;
            display: inline-block;
            min-width: 70px;
            text-align: center;
        }
        .result-field, .saldo-field {
            width: 280px;
            min-height: 60px;
            padding: 12px;
            border: 2px solid #b9cbdf;
            border-radius: 16px;
            font-family: 'Courier New', monospace;
            font-size: 1rem;
            line-height: 1.4;
            text-align: right;
            background: #f8fafd;
            resize: vertical;
            overflow: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        .saldo-field {
            border: 3px solid #1e3b5c;
            background: white;
            font-weight: 600;
            font-size: 1.1rem;
        }
        .remove-btn {
            background: #fee2e2;
            color: #dc2626;
            border: none;
            width: 50px;
            height: 50px;
            border-radius: 16px;
            font-size: 1.5rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .remove-btn:hover {
            background: #dc2626;
            color: white;
        }
        .actions-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            gap: 15px;
            flex-wrap: wrap;
        }
        .add-btn {
            background: white;
            border: 2px dashed #1e3b5c;
            border-radius: 50px;
            padding: 14px 32px;
            font-weight: 600;
            color: #1e3b5c;
            cursor: pointer;
            font-size: 1rem;
        }
        .add-btn:hover {
            background: #e1ecf7;
            border: 2px solid #1e3b5c;
        }
        .footer-total {
            margin-top: 25px;
            background: white;
            border: 4px solid #047857;
            padding: 20px 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-radius: 60px;
            font-size: 1.3rem;
            font-weight: 600;
        }
        .footer-total .amount {
            font-family: 'Courier New', monospace;
            font-size: 2.2rem;
            font-weight: 700;
            color: #047857;
            word-break: break-word;
            text-align: right;
            max-width: 60%;
        }
        .format-note {
            font-size: 0.8rem;
            margin-top: 5px;
            color: #666;
            text-align: right;
        }
        /* Ensure the calculator card doesn't inherit unwanted background */
        .calc-card * {
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', 'Courier New', monospace;
        }
    </style>
</head>
<body>
    <%- include('partials/header', { role }) %>

    <main>
        <div class="container calc-wrapper">
            <div class="calc-card">
                <h1>
                    ⚖️ Pretty Easy 
                    <small>2 DESIMAL</small>
                    <span class="badge-2d">⬆️ 1234567.89 ⬇️ 1,234,567.89</span>
                </h1>

                <div class="bulk-section">
                    <div class="bulk-title">
                        <h3>📋 Tempel Koyo</h3>
                        <span class="bulk-badge">Format: 4 (÷/x/"") 2</span>
                        <span class="feature-badge">➡️ Hasil 2 Desimal Presisi</span>
                    </div>
                    
                    <textarea id="bulkInput" placeholder="Contoh:&#10;147,106,537 x 71&#10;150 ÷ 3&#10;180,451  2"></textarea>
                    
                    <div class="bulk-options">
                        <div class="operator-selector">
                            <span class="op-option selected" data-op="none">Tanpa op</span>
                            <span class="op-option" data-op="×">× (kali)</span>
                            <span class="op-option" data-op="÷">÷ (bagi)</span>
                        </div>
                        <button class="fill-btn" id="fillBulkBtn">✨ PROSES!</button>
                        <button class="clear-btn" id="clearBulkBtn">🗑️ Buang</button>
                        <button class="reset-numbers-btn" id="resetNumbersBtn">🔄 Reset</button>
                        <span class="preview-count" id="previewCount">0 baris</span>
                    </div>
                </div>

                <!-- TOTAL ATAS - Format Murni (1234567.89) -->
                <div class="total-section">
                    <span class="total-label">TOTAL AKHIR (MURNI)</span>
                    <span class="total-value" id="grandTotalDisplay">0</span>
                </div>

                <!-- TOTAL BAWAH - Format Koma (1,234,567.89) -->
                <div class="total-section-secondary">
                    <span class="total-secondary-label">TOTAL AKHIR (KOMA)</span>
                    <span class="total-secondary-value" id="grandTotalComma">0</span>
                </div>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Input / Operator</th>
                                <th>Operator</th>
                                <th>Hasil Perhitungan</th>
                                <th>Saldo Akhir (bisa diedit)</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>

                <div class="actions-bar">
                    <button class="add-btn" id="addRowBtn">➕ Tambah Baris</button>
                    <button class="reset-numbers-btn" id="resetNumbersBtn1">🔄 Reset ke Nol</button>
                </div>

                <div class="footer-total">
                    <span class="label">Total Akhir (Footer)</span>
                    <span class="amount" id="footerTotalAmount">0</span>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        (function() {
            // ============================================
            // KALKULATOR FINAL - ANTI MONKEY TAIL
            // ============================================
            
            let barisCount = 0;
            let selectedOperator = 'none';
            
            const tbody = document.getElementById('tableBody');
            const grandTotalSpan = document.getElementById('grandTotalDisplay');
            const grandTotalComma = document.getElementById('grandTotalComma');
            const footerAmountSpan = document.getElementById('footerTotalAmount');
            const bulkInput = document.getElementById('bulkInput');
            const previewCount = document.getElementById('previewCount');
            
            // ============================================
            // FUNGSI BULATKAN 2 DESIMAL (INTI)
            // ============================================
            function bulatkan2Desimal(angka) {
                return Math.round(angka * 100) / 100;
            }
            
            // ============================================
            // FUNGSI FORMAT 2 DESIMAL
            // ============================================
            function formatMurni(angka) {
                if (angka === null || angka === undefined) return '0';
                let bulat = bulatkan2Desimal(angka);
                return bulat.toString();
            }
            
            function formatKoma(angka) {
                if (angka === null || angka === undefined) return '0';
                
                let bulat = bulatkan2Desimal(angka);
                let parts = bulat.toString().split('.');
                let bilangan = parts[0];
                
                let hasDecimal = parts.length > 1 && parts[1] !== '0';
                
                bilangan = bilangan.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                
                if (hasDecimal) {
                    return bilangan + '.' + parts[1].padEnd(2, '0');
                } else {
                    return bilangan;
                }
            }
        
            
            // ============================================
            // FUNGSI PARSE ANGKA (BENAR)
            // ============================================
            function parseAngka(teks) {
                if (!teks || typeof teks !== 'string') return 0;
                
                let original = teks.trim();
                let isNegative = original.includes('(') && original.includes(')');
                
                // Hapus Rp, spasi, kurung
                let cleaned = original.replace(/Rp/gi, '').replace(/[()]/g, '').trim();
                
                // Ganti titik dengan placeholder
                cleaned = cleaned.replace(/\./g, '***DOT***');
                // Hapus koma
                cleaned = cleaned.replace(/,/g, '');
                // Kembalikan titik
                cleaned = cleaned.replace(/\*\*\*DOT\*\*\*/g, '.');
                
                let hasil = parseFloat(cleaned) || 0;
                return isNegative ? -hasil : hasil;
            }
            
            // ============================================
            // FUNGSI PROSES BARIS
            // ============================================
            function prosesBaris(teks) {
                teks = teks.trim();
                
                let angka1 = 0;
                let angka2 = 1;
                let operator = selectedOperator === 'none' ? '×' : selectedOperator;
                
                // Deteksi operator
                if (teks.includes('x') || teks.includes('×') || teks.includes('*')) {
                    let parts;
                    if (teks.includes('x')) parts = teks.split('x');
                    else if (teks.includes('×')) parts = teks.split('×');
                    else parts = teks.split('*');
                    
                    angka1 = parseAngka(parts[0]);
                    angka2 = parseAngka(parts[1]);
                    operator = '×';
                }
                else if (teks.includes('/') || teks.includes('÷')) {
                    let parts;
                    if (teks.includes('/')) parts = teks.split('/');
                    else parts = teks.split('÷');
                    
                    angka1 = parseAngka(parts[0]);
                    angka2 = parseAngka(parts[1]);
                    operator = '÷';
                }
                else {
                    // Deteksi spasi
                    if (teks.includes(' ')) {
                        let parts = teks.split(/\s+/);
                        if (parts.length >= 2) {
                            angka1 = parseAngka(parts[0]);
                            angka2 = parseAngka(parts[1]);
                            operator = selectedOperator === 'none' ? '×' : selectedOperator;
                        } else {
                            angka1 = parseAngka(teks);
                            angka2 = 1;
                        }
                    } else {
                        angka1 = parseAngka(teks);
                        angka2 = 1;
                    }
                }
                
                // Hitung hasil
                let hasil;
                if (operator === '×') {
                    hasil = angka1 * angka2;
                } else if (operator === '÷') {
                    hasil = angka2 !== 0 ? angka1 / angka2 : 0;
                } else {
                    hasil = angka1;
                }
                
                // Format input ulang
                let inputFormatted;
                if (teks.includes('x') || teks.includes('×') || teks.includes('*') || 
                    teks.includes('/') || teks.includes('÷')) {
                    inputFormatted = teks;
                } else if (teks.includes(' ')) {
                    let parts = teks.split(/\s+/);
                    inputFormatted = `${parts[0]} ${operator} ${parts[1]}`;
                } else {
                    inputFormatted = teks;
                }
                
                return {
                    input: inputFormatted,
                    angka1: angka1,
                    angka2: angka2,
                    operator: operator,
                    hasil: hasil
                };
            }
            
            // ============================================
            // UPDATE TOTAL
            // ============================================
            function updateTotal() {
                let total = 0;
                
                for (let i = 1; i <= barisCount; i++) {
                    const saldoInput = document.getElementById(`saldo-${i}`);
                    if (saldoInput && saldoInput.value) {
                        let nilai = parseAngka(saldoInput.value);
                        total += nilai;
                    }
                }
                
                // Tampilkan dengan 2 desimal
                grandTotalSpan.textContent = formatMurni(total);        // 1234567.89
                grandTotalComma.textContent = formatKoma(total);        // 1,234,567.89
                footerAmountSpan.textContent = formatKoma(total);       // Footer pakai koma
            }
            
            // ============================================
            // TAMBAH BARIS
            // ============================================
            function tambahBaris(inputTeks = '', hasil = 0, operator = '×') {
                barisCount++;
                const id = barisCount;
                
                const row = document.createElement('tr');
                row.id = `row-${id}`;
                
                // Kolom 1: Input
                const td1 = document.createElement('td');
                const inputArea = document.createElement('textarea');
                inputArea.className = 'input-field';
                inputArea.id = `input-${id}`;
                inputArea.value = inputTeks;
                inputArea.rows = 2;
                td1.appendChild(inputArea);
                row.appendChild(td1);
                
                // Kolom 2: Operator
                const td2 = document.createElement('td');
                const opSpan = document.createElement('span');
                opSpan.className = 'operator-badge';
                opSpan.id = `op-${id}`;
                opSpan.textContent = operator;
                td2.appendChild(opSpan);
                row.appendChild(td2);
                
                // Kolom 3: Hasil (2 desimal)
                const td3 = document.createElement('td');
                const hasilArea = document.createElement('textarea');
                hasilArea.className = 'result-field';
                hasilArea.id = `hasil-${id}`;
                hasilArea.value = formatKoma(hasil);
                hasilArea.readOnly = true;
                hasilArea.rows = 2;
                td3.appendChild(hasilArea);
                row.appendChild(td3);
                
                // Kolom 4: Saldo Akhir (2 desimal)
                const td4 = document.createElement('td');
                const saldoArea = document.createElement('textarea');
                saldoArea.className = 'saldo-field';
                saldoArea.id = `saldo-${id}`;
                saldoArea.value = formatKoma(hasil);
                saldoArea.rows = 2;
                td4.appendChild(saldoArea);
                row.appendChild(td4);
                
                // Kolom 5: Aksi
                const td5 = document.createElement('td');
                const removeBtn = document.createElement('button');
                removeBtn.className = 'remove-btn';
                removeBtn.innerHTML = '✕';
                removeBtn.onclick = function() { hapusBaris(id); };
                td5.appendChild(removeBtn);
                row.appendChild(td5);
                
                tbody.appendChild(row);
                
                // Event listeners
                inputArea.addEventListener('input', function() {
                    prosesUlangBaris(id);
                });
                
                saldoArea.addEventListener('input', function() {
                    updateTotal();
                });
                
                updateTotal();
            }
            
            // ============================================
            // PROSES ULANG BARIS
            // ============================================
            function prosesUlangBaris(id) {
                const inputArea = document.getElementById(`input-${id}`);
                const opSpan = document.getElementById(`op-${id}`);
                const hasilArea = document.getElementById(`hasil-${id}`);
                const saldoArea = document.getElementById(`saldo-${id}`);
                
                const result = prosesBaris(inputArea.value);
                
                opSpan.textContent = result.operator;
                hasilArea.value = formatKoma(result.hasil);
                saldoArea.value = formatKoma(result.hasil);
                
                updateTotal();
            }
            
            // ============================================
            // HAPUS BARIS
            // ============================================
            function hapusBaris(id) {
                const row = document.getElementById(`row-${id}`);
                if (row) row.remove();
                updateTotal();
            }
            
            // ============================================
            // PROSES SEMUA
            // ============================================
            function prosesSemua() {
                const text = bulkInput.value;
                const lines = text.split('\n').filter(baris => baris.trim() !== '');
                
                if (lines.length === 0) {
                    alert('Isi dulu textarea-nya bos!');
                    return;
                }
                
                // Hapus semua baris lama
                tbody.innerHTML = '';
                barisCount = 0;
                
                // Proses setiap baris
                lines.forEach(baris => {
                    const result = prosesBaris(baris);
                    tambahBaris(result.input, result.hasil, result.operator);
                });
                
                updatePreview();
            }
            
            // ============================================
            // RESET
            // ============================================
            function resetSemua() {
                tbody.innerHTML = '';
                barisCount = 0;
                for (let i = 0; i < 3; i++) {
                    tambahBaris('', 0, '×');
                }
                updateTotal();
            }
            
            // ============================================
            // UPDATE PREVIEW
            // ============================================
            function updatePreview() {
                const lines = bulkInput.value.split('\n').filter(b => b.trim() !== '');
                previewCount.textContent = `${lines.length} baris`;
            }
            
            // ============================================
            // EVENT LISTENERS
            // ============================================
            
            document.querySelectorAll('.op-option').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.op-option').forEach(b => b.classList.remove('selected'));
                    this.classList.add('selected');
                    selectedOperator = this.getAttribute('data-op');
                });
            });
            
            document.getElementById('fillBulkBtn').addEventListener('click', prosesSemua);
            document.getElementById('clearBulkBtn').addEventListener('click', function() {
                bulkInput.value = '';
                updatePreview();
            });
            bulkInput.addEventListener('input', updatePreview);
            document.getElementById('addRowBtn').addEventListener('click', function() {
                tambahBaris('', 0, '×');
            });
            document.getElementById('resetNumbersBtn').addEventListener('click', resetSemua);
            document.getElementById('resetNumbersBtn1').addEventListener('click', resetSemua);
            
            // ============================================
            // INIT
            // ============================================
            for (let i = 0; i < 3; i++) {
                tambahBaris('', 0, '×');
            }
            updatePreview();
            
        })();
    </script>
</body>
</html>