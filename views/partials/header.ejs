<header>✨ AI Apps Dashboard</header>
<%
  const userRole = typeof role !== 'undefined' ? role : 'user';
  const isAdminOrBoss = userRole === 'admin' || userRole === 'boss';
  const canAccessHR = isAdminOrBoss || userRole === 'leader' || userRole === 'cs' || userRole === 'joker';
%>

<nav>
  <a href="/dashboard">🏠 Home</a>
  <a href="/profile">🔐 Profile & 2FA</a>
  
  <% if (isAdminOrBoss) { %>
    <a href="/admin/users">👥 Manage Users</a>
  <% } %>
  
  <% if (canAccessHR) { %>
    <a href="/hr/employees">👔 HR</a>
  <% } %>
  
  <a href="/tools/calculator">🧮 Calculator</a>
  <a href="/tools/converter">🔄 Format Converter</a>
  <a href="/phone-tracker">📱 Phone Tracker</a>
  <a href="/logout">🚪 Logout</a>
</nav>